#!/usr/bin/env bash
# Ossia Avatar — unified CLI launcher.
# Usage:
#   ./avatar setup                                  one-time install
#   ./avatar single <photo> [-o out.glb] [opts]     single photo -> textured .glb
#   ./avatar multi  --front f --left l --right r --back b [-o out.glb] [opts]
#   ./avatar mesh   <photo> [-o mesh.glb] [--render] geometry-only mesh (+ wireframe)
#   ./avatar download                               pre-fetch model weights
#   ./avatar doctor                                 check GPU / env / models
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV="$ROOT/venv"
PY="$VENV/bin/python"

need_venv() {
  if [ ! -x "$PY" ]; then
    echo "venv not found. Run:  ./avatar setup" >&2
    exit 1
  fi
}

cmd="${1:-help}"; shift || true

case "$cmd" in
  setup)
    bash "$ROOT/setup.sh" "$@"
    ;;
  single)
    need_venv; exec "$PY" "$ROOT/scripts/image2glb.py" "$@"
    ;;
  multi|mv)
    need_venv; exec "$PY" "$ROOT/scripts/image2glb_mv.py" "$@"
    ;;
  mesh|shape)
    need_venv; exec "$PY" "$ROOT/scripts/shape_only.py" "$@"
    ;;
  download)
    need_venv; exec "$PY" "$ROOT/scripts/download_models.py" "$@"
    ;;
  doctor)
    need_venv
    "$PY" - <<'PY'
try:
    import torch
    print("torch        :", torch.__version__)
    print("cuda available:", torch.cuda.is_available())
    if torch.cuda.is_available():
        print("gpu          :", torch.cuda.get_device_name(0))
        free, total = torch.cuda.mem_get_info()
        print(f"vram         : {free/1e9:.1f} GB free / {total/1e9:.1f} GB")
except Exception as e:
    print("torch        : MISSING ->", e)
PY
    ENG="$ROOT/engine"
    echo "engine       : $([ -d "$ENG/hy3dshape" ] && echo present || echo MISSING)"
    echo "realesrgan   : $([ -f "$ENG/hy3dpaint/ckpt/RealESRGAN_x4plus.pth" ] && echo present || echo MISSING)"
    echo "custom_raster: $(find "$ENG/hy3dpaint/custom_rasterizer" -name '*.so' 2>/dev/null | head -1 | grep -q . && echo built || echo 'not built')"
    df -h / | awk 'NR==2{print "disk free    : "$4}'
    ;;
  help|-h|--help|"")
    grep '^#' "$0" | sed 's/^# \{0,1\}//' | sed '1d'
    ;;
  *)
    echo "unknown command: $cmd" >&2
    echo "run ./avatar help" >&2
    exit 1
    ;;
esac
